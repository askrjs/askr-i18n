{
  "name": "@askrjs/i18n",
  "version": "0.0.1",
  "description": "Application-owned, typed internationalization scopes for Askr.",
  "keywords": [
    "askr",
    "i18n",
    "internationalization",
    "typescript"
  ],
  "homepage": "https://github.com/askrjs/askr-i18n#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-i18n/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askrjs/askr-i18n.git"
  },
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "fmt": "vp fmt .",
    "lint": "vp lint src tests vite.config.ts && npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "test": "vp test run",
    "test:publint": "publint",
    "pack:check": "npm pack --ignore-scripts --dry-run --json",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:publint && npm run pack:check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.53 <0.1.0"
  },
  "devDependencies": {
    "@askrjs/askr": "file:../askr",
    "@types/node": "^26.1.1",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@12.0.1"
}
