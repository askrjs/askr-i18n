{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "rootDir": ".",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "tests/**/*.tsx", "vite.config.ts"]
}
